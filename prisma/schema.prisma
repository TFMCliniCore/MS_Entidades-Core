generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id         Int      @id @default(autoincrement())
  nombres    String   @db.VarChar(200)
  email      String   @unique @db.VarChar(120)
  celular    String   @db.VarChar(15)
  cargo      String   @db.VarChar(200)
  roles      String   @db.VarChar(200)
  contrasena String   @db.VarChar(50)
  foto       String?  @db.VarChar(500)
  estado     String   @default("ACTIVO") @db.VarChar(20)
  sucursalId Int
  rolId      Int
  rol        Rol      @relation(fields: [rolId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("usuarios")
}

model Cliente {
  id               Int        @id @default(autoincrement())
  nombres          String     @db.VarChar(200)
  email            String     @unique @db.VarChar(120)
  celular          String     @db.VarChar(15)
  telefonoAlterno  String?    @db.VarChar(30)
  direccion        String     @db.VarChar(300)
  ciudad           String     @db.VarChar(50)
  documento        String     @unique @db.VarChar(20)
  cumpleanos       DateTime?  @db.Date
  observaciones    String?    @db.VarChar(1000)
  estado           String     @default("ACTIVO") @db.VarChar(20)
  pacientes        Paciente[]

  @@map("clientes")
}

model Paciente {
  id                Int       @id @default(autoincrement())
  nombre            String    @db.VarChar(200)
  edad              String    @db.VarChar(20)
  sexo              String    @db.VarChar(8)
  especie           String    @db.VarChar(20)
  raza              String    @db.VarChar(50)
  peso              String    @db.VarChar(20)
  castrado          Boolean   @default(false)
  foto              String?   @db.VarChar(500)
  fechaNacimiento   DateTime? @db.Date
  fechaIngreso      DateTime  @db.Date
  estado            String    @default("ACTIVO") @db.VarChar(20)
  clienteId         Int
  sedeId            Int
  historiaClinicaId Int?
  alimentoPrincipal String    @db.VarChar(500)
  cliente           Cliente   @relation(fields: [clienteId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sede              Sucursal  @relation(fields: [sedeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("pacientes")
}

model Rol {
  id          Int    @id @default(autoincrement())
  nombre      String @unique @db.VarChar(30)
  descripcion String @db.VarChar(300)
  permisoIds  Json   @default("[]") @db.JsonB
  estado      String @default("ACTIVO") @db.VarChar(20)
  usuarios    Usuario[]

  @@map("roles")
}

model Permiso {
  id          Int    @id @default(autoincrement())
  nombre      String @unique @db.VarChar(30)
  descripcion String @db.VarChar(300)
  estado      String @default("ACTIVO") @db.VarChar(20)

  @@map("permisos")
}

model Sucursal {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique @db.VarChar(200)
  direccion String     @db.VarChar(300)
  telefono  String     @db.VarChar(15)
  email     String     @unique @db.VarChar(120)
  redes     String?    @db.VarChar(500)
  logo      String?    @db.VarChar(500)
  estado    String     @default("ACTIVO") @db.VarChar(20)
  usuarios  Usuario[]
  pacientes Paciente[]

  @@map("sucursales")
}
